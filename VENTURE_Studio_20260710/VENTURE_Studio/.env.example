#
# Copy this file to .env and fill in your values before deploying.

# Backend API URL (no trailing slash)
# Dev:  leave blank — Vite proxy to localhost:4000 handles it
# Prod: VITE_API_URL=https://api.venture.app
VITE_API_URL=

# WebSocket URL for live chat
# Dev:  http://localhost:4000
# Prod: https://api.venture.app
VITE_SOCKET_URL=http://localhost:4000

# RTMP ingest server
VITE_RTMP_URL=rtmp://live.venture.app/stream

# Studio public URL (used for mobile app deep link back to studio)
# Dev:  http://localhost:3001
# Prod: https://studio.venture.app
VITE_STUDIO_URL=http://localhost:3001

# Mobile app deep link scheme
VITE_MOBILE_SCHEME=venture://
