# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nexus_db"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081
CORS_ORIGINS="http://localhost:8081,exp://localhost:8081"

# AWS S3 (for media uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=nexus-media

# Or use Cloudflare R2 / local storage in dev
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./uploads

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@nexus.gg

# Video streaming (RTMP)
RTMP_SERVER_URL=rtmp://localhost:1935/live
HLS_SERVER_URL=http://localhost:8080

# Push notifications
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=

# Platform (15% fee)
PLATFORM_FEE_RATE=0.15

# IGDB (game database)
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
