generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  username          String    @unique
  displayName       String
  email             String    @unique
  passwordHash      String?
  avatarUrl         String?
  bannerUrl         String?
  bio               String?
  pronouns          String?
  website           String?
  location          String?
  isCreator         Boolean   @default(false)
  isVerified        Boolean   @default(false)
  isGamingCreator   Boolean   @default(false)
  isLive            Boolean   @default(false)
  accountType       AccountType @default(STANDARD)
  status            UserStatus  @default(ACTIVE)
  role              UserRole    @default(USER)

  // Profile customization (MySpace-style)
  profileTheme      String?   // JSON: colors, fonts, layout
  profileMusic      String?   // URL to background music
  profileLayout     String?   // 'classic' | 'modern' | 'gaming'
  accentColor       String?   @default("#7C3AED")

  // Stats
  followersCount    Int       @default(0)
  followingCount    Int       @default(0)
  postsCount        Int       @default(0)
  totalEarnings     Float     @default(0)

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  lastSeen          DateTime  @default(now())

  // Auth providers
  oauthProviders    OAuthProvider[]

  // Content
  posts             Post[]
  stories           Story[]
  reels             Reel[]
  clips             GameClip[]
  lives             LiveStream[]

  // Social
  followers         Follow[]  @relation("FollowerRelation")
  following         Follow[]  @relation("FollowingRelation")
  likes             Like[]
  comments          Comment[]
  bookmarks         Bookmark[]
  shares            Share[]

  // Messaging
  sentMessages      Message[]       @relation("SentMessages")
  messageThreads    ThreadMember[]

  // Monetization
  creatorProfile    CreatorProfile?
  subscriptions     Subscription[]  @relation("SubscriberRelation")
  subscribers       Subscription[]  @relation("CreatorRelation")
  tips              Tip[]           @relation("TipReceiver")
  tipsSent          Tip[]           @relation("TipSender")
  purchases         Purchase[]

  // Gaming
  gamerProfile      GamerProfile?
  gameLibrary       GameLibraryEntry[]
  achievements      UserAchievement[]
  tournamentEntries TournamentEntry[]

  // Notifications
  notifications     Notification[]
  notifPrefs        NotificationPreference?

  // Community
  communities       CommunityMember[]
  ownedCommunities  Community[]

  // Import
  importJobs        ImportJob[]

  // Reports
  reportsFile       Report[] @relation("Reporter")
  reportsReceived   Report[] @relation("Reported")

  // Security & moderation
  bannedAt              DateTime?
  banReason             String?     // 'CSAM_DETECTION' | 'TOS_VIOLATION' | 'MANUAL'
  // Push notifications — never stored for Kids Mode sessions (enforced by kidsPrivacyGuard)
  pushToken             String?
  pushTokenUpdatedAt    DateTime?

  @@index([username])
  @@index([email])
  @@index([createdAt])
}

enum AccountType {
  STANDARD
  CREATOR
  PARTNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DEACTIVATED
}

enum UserRole {
  USER
  MODERATOR
  STAFF
  ADMIN
}

model OAuthProvider {
  id           String @id @default(uuid())
  userId       String
  provider     String  // 'google' | 'twitch' | 'discord' | 'twitter' | 'youtube'
  providerId   String
  accessToken  String?
  refreshToken String?
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
}

// ─────────────────────────────────────────────
// SOCIAL GRAPH
// ─────────────────────────────────────────────

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  notifyPosts Boolean  @default(true)
  notifyLive  Boolean  @default(true)
  createdAt   DateTime @default(now())

  follower    User @relation("FollowerRelation", fields: [followerId], references: [id], onDelete: Cascade)
  following   User @relation("FollowingRelation", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

// ─────────────────────────────────────────────
// CONTENT — POSTS, REELS, STORIES, CLIPS
// ─────────────────────────────────────────────

model Post {
  id            String      @id @default(uuid())
  authorId      String
  content       String?
  mediaUrls     String[]    // array of image/video URLs
  mediaTypes    String[]    // 'image' | 'video' | 'audio'
  thumbnailUrl  String?
  type          PostType    @default(TEXT)
  visibility    Visibility  @default(PUBLIC)
  isPinned      Boolean     @default(false)
  isNSFW        Boolean     @default(false)
  tags          String[]
  gameTag       String?     // linked game
  locationTag   String?
  feelingTag    String?

  // Engagement
  likesCount    Int         @default(0)
  commentsCount Int         @default(0)
  sharesCount   Int         @default(0)
  viewsCount    Int         @default(0)
  bookmarksCount Int        @default(0)

  // Monetization
  isExclusive   Boolean     @default(false)  // subscriber-only
  tierRequired  String?     // minimum tier ID to view

  // Content Management
  isPublished      Boolean     @default(true)
  scheduledFor     DateTime?   // alias kept; also used for drop scheduling
  contentRating    ContentRating @default(EVERYONE)
  madeForKids      Boolean     @default(false)
  ageRestricted    Boolean     @default(false)
  commentsMode     CommentMode @default(OPEN)
  pinnedCommentId  String?
  tipsEnabled      Boolean     @default(true)
  paidUnlockPrice  Float?      // one-time pay-to-view price
  featuredOnProfile Boolean    @default(false)
  allowDuet        Boolean     @default(true)
  allowRemix       Boolean     @default(true)
  callToAction     Json?       // { type: CallToActionType, label, url, targetId }
  customThumbnail  String?
  timezone         String?     // for scheduled drops display
  dropCountdownMsg String?     // "Dropping in..."
  editHistory      Json?       // array of edit timestamps + fields changed
  collectionId     String?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  author        User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes         Like[]
  comments      Comment[]
  bookmarks     Bookmark[]
  shares        Share[]
  communityId   String?
  community     Community?  @relation(fields: [communityId], references: [id])

  @@index([authorId])
  @@index([createdAt])
  @@index([type])
  @@index([tags])
}

enum PostType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  BLOG
  POLL
  CLIP
  LIVE_HIGHLIGHT
}

enum Visibility {
  PUBLIC
  FOLLOWERS_ONLY
  SUBSCRIBERS_ONLY
  PRIVATE
  UNLISTED
}


enum ContentRating {
  EVERYONE
  TEEN
  MATURE
}

enum CommentMode {
  OPEN
  REVIEW  // hold for approval
  DISABLED
}

enum CallToActionType {
  SUBSCRIBE
  FOLLOW
  TIP
  VISIT_LINK
  WATCH_NEXT
}

model Reel {
  id           String    @id @default(uuid())
  authorId     String
  videoUrl     String
  thumbnailUrl String?
  caption      String?
  audioTrack   String?
  audioName    String?
  duration     Int       // seconds
  tags         String[]
  gameTag      String?
  visibility   Visibility @default(PUBLIC)
  isNSFW       Boolean   @default(false)

  likesCount   Int       @default(0)
  commentsCount Int      @default(0)
  sharesCount  Int       @default(0)
  viewsCount   Int       @default(0)
  savesCount   Int       @default(0)

  isExclusive  Boolean   @default(false)
  // Content Management
  isPublished      Boolean   @default(true)
  scheduledFor     DateTime?
  contentRating    ContentRating @default(EVERYONE)
  madeForKids      Boolean   @default(false)
  ageRestricted    Boolean   @default(false)
  commentsMode     CommentMode @default(OPEN)
  pinnedCommentId  String?
  tipsEnabled      Boolean   @default(true)
  allowDuet        Boolean   @default(true)
  allowRemix       Boolean   @default(true)
  featuredOnProfile Boolean  @default(false)
  callToAction     Json?
  customThumbnail  String?
  collectionId     String?

  createdAt    DateTime  @default(now())
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes        Like[]
  comments     Comment[]

  @@index([authorId])
  @@index([createdAt])
}

model Story {
  id           String    @id @default(uuid())
  authorId     String
  mediaUrl     String
  mediaType    String    // 'image' | 'video'
  duration     Int       @default(5) // seconds to display
  caption      String?
  sticker      String?   // JSON sticker data
  poll         String?   // JSON poll data
  questionBox  String?
  link         String?
  visibility   Visibility @default(PUBLIC)
  viewsCount   Int       @default(0)
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views        StoryView[]

  @@index([authorId])
  @@index([expiresAt])
}

model StoryView {
  id        String   @id @default(uuid())
  storyId   String
  viewerId  String
  viewedAt  DateTime @default(now())
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, viewerId])
}

model GameClip {
  id           String    @id @default(uuid())
  authorId     String
  gameId       String
  videoUrl     String
  thumbnailUrl String?
  title        String
  description  String?
  duration     Int
  tags         String[]
  visibility   Visibility @default(PUBLIC)

  likesCount   Int       @default(0)
  commentsCount Int      @default(0)
  viewsCount   Int       @default(0)

  createdAt    DateTime  @default(now())
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  game         Game      @relation(fields: [gameId], references: [id])
  likes        Like[]
  comments     Comment[]

  @@index([authorId])
  @@index([gameId])
}

// ─────────────────────────────────────────────
// LIVE STREAMING
// ─────────────────────────────────────────────

model LiveStream {
  id            String       @id @default(uuid())
  hostId        String
  title         String
  description   String?
  thumbnailUrl  String?
  streamKey     String       @unique @default(uuid())
  playbackUrl   String?
  gameId        String?
  tags          String[]
  category      String?
  visibility    Visibility   @default(PUBLIC)
  status        StreamStatus @default(SCHEDULED)
  isRecorded    Boolean      @default(true)

  viewerCount   Int          @default(0)
  peakViewers   Int          @default(0)
  totalViews    Int          @default(0)
  chatCount     Int          @default(0)

  startedAt     DateTime?
  endedAt       DateTime?
  scheduledFor  DateTime?
  createdAt     DateTime     @default(now())

  host          User         @relation(fields: [hostId], references: [id], onDelete: Cascade)
  game          Game?        @relation(fields: [gameId], references: [id])
  chatMessages  LiveChatMessage[]
  superChats    SuperChat[]

  @@index([hostId])
  @@index([status])
}

enum StreamStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model LiveChatMessage {
  id          String   @id @default(uuid())
  streamId    String
  userId      String
  username    String
  message     String
  color       String?  // username color
  badges      String[] // subscriber, moderator, etc.
  isSuperChat Boolean  @default(false)
  amount      Float?   // if superchat
  createdAt   DateTime @default(now())

  stream      LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
  @@index([createdAt])
}

model SuperChat {
  id        String   @id @default(uuid())
  streamId  String
  senderId  String
  message   String?
  amount    Float
  currency  String   @default("USD")
  color     String   // based on amount tier
  createdAt DateTime @default(now())

  stream    LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@index([streamId])
}

// ─────────────────────────────────────────────
// ENGAGEMENT
// ─────────────────────────────────────────────

model Like {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  reelId    String?
  clipId    String?
  commentId String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reel      Reel?    @relation(fields: [reelId], references: [id], onDelete: Cascade)
  clip      GameClip? @relation(fields: [clipId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, reelId])
  @@unique([userId, clipId])
  @@index([postId])
  @@index([reelId])
}

model Comment {
  id           String   @id @default(uuid())
  authorId     String
  postId       String?
  reelId       String?
  clipId       String?
  parentId     String?
  content      String
  mediaUrl     String?
  likesCount   Int      @default(0)
  repliesCount Int      @default(0)
  isEdited     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post         Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  reel         Reel?    @relation(fields: [reelId], references: [id], onDelete: Cascade)
  clip         GameClip? @relation(fields: [clipId], references: [id], onDelete: Cascade)
  parent       Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies      Comment[] @relation("CommentReplies")
  likes        Like[]

  @@index([postId])
  @@index([reelId])
  @@index([authorId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Share {
  id        String   @id @default(uuid())
  userId    String
  postId    String?
  platform  String?  // 'nexus' | 'external'
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post? @relation(fields: [postId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// MESSAGING
// ─────────────────────────────────────────────

model MessageThread {
  id           String         @id @default(uuid())
  name         String?        // for group chats
  avatarUrl    String?
  isGroup      Boolean        @default(false)
  lastMessage  String?
  lastActivity DateTime       @default(now())
  createdAt    DateTime       @default(now())

  members      ThreadMember[]
  messages     Message[]
}

model ThreadMember {
  id          String        @id @default(uuid())
  threadId    String
  userId      String
  role        String        @default("member") // 'admin' | 'member'
  unreadCount Int           @default(0)
  joinedAt    DateTime      @default(now())
  lastRead    DateTime      @default(now())
  isMuted     Boolean       @default(false)

  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
}

model Message {
  id          String        @id @default(uuid())
  threadId    String
  senderId    String
  content     String?
  mediaUrl    String?
  mediaType   String?
  type        MessageType   @default(TEXT)
  isEdited    Boolean       @default(false)
  isDeleted   Boolean       @default(false)
  replyToId   String?
  createdAt   DateTime      @default(now())

  thread      MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender      User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  replyTo     Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     Message[]     @relation("MessageReplies")

  @@index([threadId])
  @@index([createdAt])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  GIF
  STICKER
  CLIP_SHARE
  POST_SHARE
  SYSTEM
}

// ─────────────────────────────────────────────
// GAMING
// ─────────────────────────────────────────────

model Game {
  id            String   @id @default(uuid())
  name          String   @unique
  slug          String   @unique
  coverUrl      String?
  bannerUrl     String?
  description   String?
  genre         String[]
  platform      String[]
  developer     String?
  publisher     String?
  releaseDate   DateTime?
  igdbId        String?  @unique
  twitchGameId  String?
  isPopular     Boolean  @default(false)
  viewerCount   Int      @default(0)
  clipCount     Int      @default(0)
  streamCount   Int      @default(0)
  createdAt     DateTime @default(now())

  clips         GameClip[]
  lives         LiveStream[]
  libraryEntries GameLibraryEntry[]
  achievements  GameAchievement[]

  @@index([name])
  @@index([isPopular])
}

model GamerProfile {
  id              String   @id @default(uuid())
  userId          String   @unique
  gamerTag        String?
  level           Int      @default(1)
  xp              Int      @default(0)
  rank            String?
  totalPlaytime   Int      @default(0) // hours
  favoriteGames   String[]
  platforms       String[] // 'pc' | 'ps5' | 'xbox' | 'switch' | 'mobile'

  // Connected accounts
  steamId         String?
  psnId           String?
  xboxGamertag    String?
  riotId          String?
  battleNetTag    String?
  epicId          String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameLibraryEntry {
  id          String   @id @default(uuid())
  userId      String
  gameId      String
  status      String   @default("playing") // 'playing' | 'completed' | 'wishlist' | 'dropped'
  hoursPlayed Int      @default(0)
  rating      Float?
  review      String?
  addedAt     DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game @relation(fields: [gameId], references: [id])

  @@unique([userId, gameId])
}

model GameAchievement {
  id          String  @id @default(uuid())
  gameId      String
  name        String
  description String?
  iconUrl     String?
  rarity      String  @default("common") // 'common' | 'rare' | 'epic' | 'legendary'
  xpReward    Int     @default(10)

  game        Game    @relation(fields: [gameId], references: [id])
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String          @id @default(uuid())
  userId        String
  achievementId String
  earnedAt      DateTime        @default(now())

  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   GameAchievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model Tournament {
  id           String    @id @default(uuid())
  gameId       String?
  hostId       String?
  name         String
  description  String?
  bannerUrl    String?
  prizePool    Float     @default(0)
  currency     String    @default("USD")
  format       String    // '1v1' | 'team' | 'battle_royale'
  maxEntrants  Int       @default(64)
  status       String    @default("open")
  startsAt     DateTime
  createdAt    DateTime  @default(now())

  entries      TournamentEntry[]
}

model TournamentEntry {
  id           String     @id @default(uuid())
  tournamentId String
  userId       String
  teamName     String?
  seed         Int?
  placement    Int?
  registeredAt DateTime   @default(now())

  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
}

// ─────────────────────────────────────────────
// MONETIZATION
// ─────────────────────────────────────────────

model CreatorProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  stripeAccountId    String?
  stripeOnboarded    Boolean  @default(false)
  paypalEmail        String?
  isMonetized        Boolean  @default(false)

  // Earnings
  totalEarned        Float    @default(0)
  pendingPayout      Float    @default(0)
  totalPaidOut       Float    @default(0)
  platformFeeRate    Float    @default(0.15) // 15% platform fee

  // Creator page
  tagline            String?
  thankYouMessage    String?
  goalAmount         Float?
  goalDescription    String?
  goalCurrent        Float    @default(0)

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionTiers  SubscriptionTier[]
  payouts            Payout[]
  transactions       Transaction[]
}

model SubscriptionTier {
  id            String   @id @default(uuid())
  creatorId     String
  name          String
  description   String?
  price         Float
  currency      String   @default("USD")
  interval      String   @default("month") // 'month' | 'year'
  color         String   @default("#7C3AED")
  perks         String[] // list of perks
  isActive      Boolean  @default(true)
  stripePriceId String?
  sortOrder     Int      @default(0)

  createdAt     DateTime @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  subscriptions  Subscription[]

  @@index([creatorId])
}

model Subscription {
  id              String   @id @default(uuid())
  subscriberId    String
  creatorId       String
  tierId          String
  status          String   @default("active") // 'active' | 'cancelled' | 'expired' | 'paused'
  stripeSubId     String?  @unique
  amount          Float
  currency        String   @default("USD")
  interval        String   @default("month")
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriber      User     @relation("SubscriberRelation", fields: [subscriberId], references: [id], onDelete: Cascade)
  creator         User     @relation("CreatorRelation", fields: [creatorId], references: [id], onDelete: Cascade)
  tier            SubscriptionTier @relation(fields: [tierId], references: [id])

  @@index([subscriberId])
  @@index([creatorId])
}

model Tip {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  amount      Float
  currency    String   @default("USD")
  message     String?
  isAnonymous Boolean  @default(false)
  platformFee Float    // 15% of amount
  netAmount   Float    // amount - platformFee
  stripePaymentId String?
  status      String   @default("completed")
  createdAt   DateTime @default(now())

  sender      User @relation("TipSender", fields: [senderId], references: [id])
  receiver    User @relation("TipReceiver", fields: [receiverId], references: [id])

  @@index([receiverId])
  @@index([senderId])
}

model Purchase {
  id          String   @id @default(uuid())
  buyerId     String
  itemType    String   // 'merch' | 'digital' | 'exclusive_post'
  itemId      String
  amount      Float
  platformFee Float
  netAmount   Float
  status      String   @default("completed")
  createdAt   DateTime @default(now())

  buyer       User @relation(fields: [buyerId], references: [id])

  @@index([buyerId])
}

model Transaction {
  id          String   @id @default(uuid())
  creatorId   String
  type        String   // 'subscription' | 'tip' | 'superchat' | 'merch' | 'purchase'
  amount      Float
  platformFee Float
  netAmount   Float
  description String?
  createdAt   DateTime @default(now())

  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([createdAt])
}

model Payout {
  id          String   @id @default(uuid())
  creatorId   String
  amount      Float
  currency    String   @default("USD")
  method      String   // 'stripe' | 'paypal'
  status      String   @default("pending") // 'pending' | 'processing' | 'paid' | 'failed'
  stripePayoutId String?
  requestedAt DateTime @default(now())
  processedAt DateTime?

  creator     CreatorProfile @relation(fields: [creatorId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// COMMUNITIES
// ─────────────────────────────────────────────

model Community {
  id           String   @id @default(uuid())
  ownerId      String
  name         String   @unique
  slug         String   @unique
  description  String?
  avatarUrl    String?
  bannerUrl    String?
  isPublic     Boolean  @default(true)
  isVerified   Boolean  @default(false)
  gameId       String?
  tags         String[]
  rules        String[] // community rules

  memberCount  Int      @default(0)
  postCount    Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner        User     @relation(fields: [ownerId], references: [id])
  members      CommunityMember[]
  posts        Post[]

  @@index([slug])
  @@index([isPublic])
}

model CommunityMember {
  id          String    @id @default(uuid())
  communityId String
  userId      String
  role        String    @default("member") // 'owner' | 'moderator' | 'member'
  joinedAt    DateTime  @default(now())
  isBanned    Boolean   @default(false)

  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id          String   @id @default(uuid())
  userId      String
  type        String   // 'like' | 'comment' | 'follow' | 'mention' | 'sub' | 'tip' | 'live' | 'achievement'
  title       String
  body        String
  data        String?  // JSON payload
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@index([isRead])
}

model NotificationPreference {
  id              String @id @default(uuid())
  userId          String @unique
  likes           Boolean @default(true)
  comments        Boolean @default(true)
  follows         Boolean @default(true)
  mentions        Boolean @default(true)
  newSubscriber   Boolean @default(true)
  tips            Boolean @default(true)
  liveStart       Boolean @default(true)
  newPost         Boolean @default(false)
  achievements    Boolean @default(true)
  push            Boolean @default(true)
  email           Boolean @default(true)

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// PLATFORM IMPORT
// ─────────────────────────────────────────────

model ImportJob {
  id           String   @id @default(uuid())
  userId       String
  platform     String   // 'youtube' | 'twitter' | 'instagram' | 'twitch' | 'tiktok'
  status       String   @default("pending") // 'pending' | 'processing' | 'complete' | 'failed'
  progress     Int      @default(0)
  itemsFound   Int      @default(0)
  itemsImported Int     @default(0)
  errorMessage String?
  config       String?  // JSON config for what to import
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

// ─────────────────────────────────────────────
// DISCOVERY & TRENDING
// ─────────────────────────────────────────────

model TrendingTopic {
  id         String   @id @default(uuid())
  tag        String   @unique
  postCount  Int      @default(0)
  score      Float    @default(0)
  category   String?
  updatedAt  DateTime @updatedAt

  @@index([score])
}

model Report {
  id          String   @id @default(uuid())
  reporterId  String
  reportedId  String
  contentType String   // 'post' | 'reel' | 'user' | 'comment' | 'stream'
  contentId   String
  reason      String
  details     String?
  status      String   @default("pending") // 'pending' | 'reviewed' | 'resolved' | 'dismissed'
  createdAt   DateTime @default(now())

  reporter    User @relation("Reporter", fields: [reporterId], references: [id])
  reported    User @relation("Reported", fields: [reportedId], references: [id])
}

// ─────────────────────────────────────────────
// ANALYTICS
// ─────────────────────────────────────────────

model AnalyticsEvent {
  id         String   @id @default(uuid())
  userId     String?
  event      String
  properties String?  // JSON
  sessionId  String?
  platform   String?  // 'ios' | 'android' | 'web'
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([event])
  @@index([createdAt])
}

// ─────────────────────────────────────────────
// COMMUNITY CHAT ROOMS
// ─────────────────────────────────────────────

model ChatRoom {
  id            String    @id @default(uuid())
  type          ChatRoomType
  name          String
  description   String?
  slug          String    @unique
  regionCode    String?   // area code or country code e.g. "212", "44", "US-CA"
  regionName    String?   // "New York City", "United Kingdom", "California"
  countryCode   String?   // ISO 2-letter: "US", "GB", "JP"
  flagEmoji     String?   // "🇺🇸", "🇬🇧"
  language      String?   // primary language
  isActive      Boolean   @default(true)
  isLocked      Boolean   @default(false)  // admins only can lock during incidents
  slowMode      Int       @default(0)      // seconds between messages per user (0 = off)
  memberCount   Int       @default(0)
  messageCount  Int       @default(0)
  onlineCount   Int       @default(0)
  createdAt     DateTime  @default(now())

  messages      ChatRoomMessage[]
  members       ChatRoomMember[]
  moderators    ChatRoomModerator[]
  bans          ChatRoomBan[]

  @@index([type])
  @@index([regionCode])
  @@index([countryCode])
  @@index([slug])
}

enum ChatRoomType {
  WORLD       // single global room
  COUNTRY     // per country
  REGION      // per US state / world region
  AREA_CODE   // per phone area code (US/Canada)
  CITY        // major cities worldwide
}

model ChatRoomMessage {
  id            String    @id @default(uuid())
  roomId        String
  userId        String
  username      String    // denormalized for speed
  displayName   String
  avatarUrl     String?
  content       String
  originalContent String? // stores original before censorship
  wasCensored   Boolean   @default(false)
  isDeleted     Boolean   @default(false)
  deletedBy     String?   // userId of mod who deleted
  deleteReason  String?
  isSystemMsg   Boolean   @default(false)
  isPinned      Boolean   @default(false)
  replyToId     String?
  badges        String[]  // ['verified', 'moderator', 'admin', 'creator', 'subscriber']
  reactions     String?   // JSON: {"❤️": 5, "🔥": 3}
  reportCount   Int       @default(0)
  autoFlagged   Boolean   @default(false) // flagged by filter
  createdAt     DateTime  @default(now())

  room          ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reports       ChatMessageReport[]
  replyTo       ChatRoomMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies       ChatRoomMessage[] @relation("MessageReplies")

  @@index([roomId])
  @@index([createdAt])
  @@index([userId])
}

model ChatRoomMember {
  id          String    @id @default(uuid())
  roomId      String
  userId      String
  joinedAt    DateTime  @default(now())
  lastSeen    DateTime  @default(now())
  isMuted     Boolean   @default(false)
  muteExpiry  DateTime?
  messageCount Int      @default(0)

  room        ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
}

model ChatRoomModerator {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  addedBy   String
  addedAt   DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model ChatRoomBan {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  bannedBy  String
  reason    String?
  expiresAt DateTime?  // null = permanent
  bannedAt  DateTime   @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
}

model ChatMessageReport {
  id          String   @id @default(uuid())
  messageId   String
  reporterId  String
  reason      String   // 'spam' | 'harassment' | 'inappropriate' | 'hate_speech' | 'other'
  details     String?
  status      String   @default("pending")
  reviewedBy  String?
  createdAt   DateTime @default(now())

  message     ChatRoomMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
}

model ProfanityWord {
  id        String @id @default(uuid())
  word      String @unique
  severity  Int    @default(1)  // 1=mild, 2=moderate, 3=severe
  addedBy   String?
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// CONTENT COLLECTIONS & PLAYLISTS
// ─────────────────────────────────────────────

model Collection {
  id          String   @id @default(uuid())
  creatorId   String
  title       String
  description String?
  coverUrl    String?
  isPublic    Boolean  @default(true)
  sortOrder   Int      @default(0)
  itemCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator     User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
}

model ScheduledDrop {
  id           String   @id @default(uuid())
  creatorId    String
  contentId    String   // postId, reelId, or storyId
  contentType  String   // 'post' | 'reel' | 'story'
  scheduledFor DateTime
  timezone     String   @default("UTC")
  title        String?
  status       String   @default("pending") // pending | published | cancelled
  createdAt    DateTime @default(now())

  creator      User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([creatorId])
  @@index([scheduledFor])
  @@index([status])
}

model PendingComment {
  id        String   @id @default(uuid())
  postId    String?
  reelId    String?
  authorId  String
  content   String
  createdAt DateTime @default(now())

  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([reelId])
}



// ── Content fingerprint — perceptual hash index for duplicate detection ────────
model ContentFingerprint {
  id          String   @id @default(uuid())
  contentId   String   @unique           // UUID of the Post/Reel/Clip/Story
  contentType String                     // 'post' | 'reel' | 'story' | 'clip' | 'video'
  creatorId   String
  sha256      String                     // exact SHA-256 of raw upload (fast exact match)
  frameHashes String[]                   // dHash of each extracted frame
  createdAt   DateTime @default(now())

  @@index([creatorId])
  @@index([sha256])
}

// ─────────────────────────────────────────────────────────────────────────────
//  CHILD SAFETY — CSAM Detection Models
//  These records are immutable once created. Retain for 10 years per NCMEC
//  compliance requirements under 18 U.S.C. § 2258A.
// ─────────────────────────────────────────────────────────────────────────────

model CsamIncident {
  id                    String    @id @default(uuid())
  userId                String    // Uploader — account is suspended on creation
  fileHash              String    // SHA-256 of the offending file
  pHash                 String?   // Perceptual hash (if computed)
  matchSource           String    // 'redis_sha256' | 'azure_content_safety' | 'phash'
  ncmecReportId         String?   // NCMEC CyberTipline report ID
  ncmecReportSubmitted  Boolean   @default(false)
  ipAddress             String?   // Hashed, not plaintext
  requestId             String?   // Correlation ID
  retainUntil           DateTime  // 10-year retention floor
  createdAt             DateTime  @default(now())

  // No relation to User — deliberate. The user account may be deleted
  // but this record must persist for law enforcement purposes.

  @@index([userId])
  @@index([fileHash])
  @@index([createdAt])
}

model CsamBlockedHash {
  id         String   @id @default(uuid())
  sha256Hash String   @unique
  pHash      String?  // Perceptual hash variant for fuzzy matching
  source     String   // 'NCMEC' | 'IWF' | 'INHOPE' | 'MANUAL'
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([sha256Hash])
}
